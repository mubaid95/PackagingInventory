<Window x:Class="PackagingInventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PackagingInventory.Views"
        mc:Ignorable="d"
        Title="📦 Packaging Inventory"
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <TabControl>
            <!-- Dashboard Tab -->
            <TabItem Header="Dashboard">
                <views:DashboardView/>
            </TabItem>

            <!-- GoDown Tab -->
            <TabItem Header="GoDown">
                <views:GodownHistoryView/>
            </TabItem>

            <!-- Customer Data -->
            <TabItem Header="Customer">
                <views:CustomerDataView/>
            </TabItem>

            <!-- Supplier Tab -->
            <TabItem Header="Supplier Data">
                <views:SupplierDataPage/>
            </TabItem>

            <!-- Miscellaneous Tab -->
            <TabItem Header="Miscellaneous">
                <views:MiscellaneousCostPage/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
